# Database — PostgreSQL (Docker local ou VPS)
# Local:  docker compose up -d && use a URL abaixo
DATABASE_URL="postgresql://sobrapsi:sobrapsi@127.0.0.1:5433/sobrapsi?schema=public"

# Docker Compose (opcional — sobrescreve defaults do postgres)
POSTGRES_USER="sobrapsi"
POSTGRES_PASSWORD="sobrapsi"
POSTGRES_DB="sobrapsi"
POSTGRES_PORT="5433"
POSTGRES_BIND="127.0.0.1"

# Session (gere um valor longo e aleatório em produção)
SESSION_SECRET="change-me-to-a-long-random-string-in-production"

# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NODE_ENV="development"

# Admin
ADMIN_SECRET="change-me-in-production"

# Pagamentos — Mercado Pago (checkout transparente)
# Local (MP_ENV=test): cartão de teste exige Credenciais de TESTE da integração.
# Produção (MP_ENV=production): use Credenciais de produção e cartões reais.
MP_ENV="test"
MP_ACCESS_TOKEN=""
MP_PUBLIC_KEY=""
NEXT_PUBLIC_MP_PUBLIC_KEY=""
MP_ACCESS_TOKEN_TEST=""
MP_PUBLIC_KEY_TEST=""
NEXT_PUBLIC_MP_PUBLIC_KEY_TEST=""
# Opcional: Parcelado Vendedor (padrão 1). Use "0" para desativar.
MP_DIFFERENTIAL_PRICING_ID="1"
MP_MAX_INTEREST_FREE_INSTALLMENTS="12"
# Em local, omita webhook (localhost é inválido). Em produção use a URL pública.
# MP_NOTIFICATION_URL="https://sobrapsi.org.br/api/webhooks/mercadopago"

ANNUAL_FEE_CARD_AMOUNT="600"
ANNUAL_FEE_CASH_AMOUNT="500"
ANNUAL_FEE_INSTALLMENTS="12"
APPLICATION_FEE_CARD_AMOUNT="600"
APPLICATION_FEE_CASH_AMOUNT="500"

# Fallback de desenvolvimento (somente local)
NEXT_PUBLIC_ALLOW_SIMULATED_PAYMENTS="false"
ALLOW_SIMULATED_PAYMENTS="false"
SOBRAPSI_CNPJ="52.279.751/0001-92"

# Cron (systemd/crontab na VPS)
CRON_SECRET="change-me-in-production"

# E-mails (opcional)
RESEND_API_KEY=""
EMAIL_FROM="SOBRAPSI <noreply@sobrapsi.org.br>"

# Encryption key for CPF/RG (32 bytes hex — obrigatório em produção)
ENCRYPTION_KEY=""
