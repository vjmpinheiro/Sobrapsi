# Copie para .env na VPS: cp .env.production.example .env
# Ajuste domínio, senhas e segredos antes do primeiro deploy.

NODE_ENV="production"

# PostgreSQL (container Docker na mesma VPS)
DATABASE_URL="postgresql://sobrapsi:TROQUE_ESTA_SENHA@127.0.0.1:5432/sobrapsi?schema=public"
POSTGRES_USER="sobrapsi"
POSTGRES_PASSWORD="TROQUE_ESTA_SENHA"
POSTGRES_DB="sobrapsi"
POSTGRES_PORT="5432"
POSTGRES_BIND="127.0.0.1"

# App
NEXT_PUBLIC_APP_URL="https://sobrapsi.org.br"

# Segredos — gere valores únicos (openssl rand -hex 32)
SESSION_SECRET=""
ADMIN_SECRET=""
CRON_SECRET=""
ENCRYPTION_KEY=""

# Pagamentos — Mercado Pago
MP_ENV="production"
MP_ACCESS_TOKEN=""
MP_PUBLIC_KEY=""
MP_DIFFERENTIAL_PRICING_ID="1"
MP_MAX_INTEREST_FREE_INSTALLMENTS="12"
ANNUAL_FEE_CARD_AMOUNT="600"
ANNUAL_FEE_CASH_AMOUNT="500"
ANNUAL_FEE_INSTALLMENTS="12"
APPLICATION_FEE_CARD_AMOUNT="600"
APPLICATION_FEE_CASH_AMOUNT="500"
NEXT_PUBLIC_ALLOW_SIMULATED_PAYMENTS="false"
ALLOW_SIMULATED_PAYMENTS="false"
SOBRAPSI_CNPJ="52.279.751/0001-92"

# E-mails
RESEND_API_KEY=""
EMAIL_FROM="SOBRAPSI <noreply@sobrapsi.org.br>"
